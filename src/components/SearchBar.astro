---
export interface Props {
  defaultValue?: string;
}

const { defaultValue = "" } = Astro.props;
---

<div class="relative">
  <svg
    class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-400"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.5"
    stroke="currentColor"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
  </svg>
  <input
    id="search-input"
    type="text"
    placeholder="搜索资源名称、描述、标签..."
    value={defaultValue}
    class="w-full rounded-xl border border-white/30 bg-white/40 py-2.5 pl-10 pr-4 text-sm text-zinc-900 placeholder:text-zinc-400 backdrop-blur-md transition-colors focus:border-teal-400 focus:outline-none focus:ring-1 focus:ring-teal-400 focus:bg-white/60"
  />
</div>
