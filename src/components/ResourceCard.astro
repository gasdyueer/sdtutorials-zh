---
import type { CategoryKey } from "../data/resources";

export interface Props {
  title: string;
  url: string;
  description: string;
  category: CategoryKey;
  tags: string[];
}

const { title, url, description, category, tags } = Astro.props;

const categoryLabel: Record<CategoryKey, string> = {
  website: "网站",
  creator: "UP主",
  article: "文章",
};
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="card group block"
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-base font-medium text-zinc-900 transition-colors group-hover:text-teal-600">
      {title}
    </h3>
    <span class={`badge badge-${category}`}>
      {categoryLabel[category]}
    </span>
  </div>
  <p class="mt-2 text-sm leading-relaxed text-zinc-500 line-clamp-3">
    {description}
  </p>
  <div class="mt-3 flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="rounded-md bg-zinc-100 px-2 py-0.5 text-xs text-zinc-500">
        {tag}
      </span>
    ))}
  </div>
</a>
